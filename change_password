<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>SPark — Change Password</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.22.2/firebase-auth-compat.js"></script>
  <script>
    firebase.initializeApp({
      apiKey: "AIzaSyAuSXP4AeKXNnO1Uyj3Ds5soheQXzedsmk",
      authDomain: "smart-parking-60139.firebaseapp.com",
      databaseURL: "https://smart-parking-60139-default-rtdb.asia-southeast1.firebasedatabase.app",
      projectId: "smart-parking-60139",
      storageBucket: "smart-parking-60139.appspot.com",
      messagingSenderId: "284320423783",
      appId: "1:284320423783:web:535b714ab14f70597899c2"
    });
    const auth = firebase.auth();

    document.addEventListener("DOMContentLoaded", function(){ document.body.style.opacity="0"; });

    auth.onAuthStateChanged(function(user) {
      if (!user) { window.location.replace("login.html"); return; }
      document.body.style.transition = "opacity 0.4s ease";
      document.body.style.opacity   = "1";
      document.getElementById("userEmail").textContent = user.email;
    });

    function getStrength(pwd) {
      let s=0;
      if (pwd.length>=8) s++;
      if (/[A-Z]/.test(pwd)) s++;
      if (/[a-z]/.test(pwd)) s++;
      if (/[0-9]/.test(pwd)) s++;
      if (/[^A-Za-z0-9]/.test(pwd)) s++;
      return s; // 0-5
    }

    function updateStrength(pwd) {
      const s = getStrength(pwd);
      const segs = document.querySelectorAll(".sb-seg");
      const lbl  = document.getElementById("strengthLbl");
      const labels = ["","Very Weak","Weak","Fair","Strong","Very Strong"];
      const colors = ["","#f05252","#f97316","#f6c90e","#22c55e","#c8f135"];
      segs.forEach(function(seg, i){
        seg.style.background = i<s ? colors[s] : "var(--border)";
      });
      lbl.textContent = labels[s]||"";
      lbl.style.color = colors[s]||"var(--mu)";
    }

    function doChangePassword() {
      const curr = document.getElementById("currPwd").value;
      const np   = document.getElementById("newPwd").value;
      const cp   = document.getElementById("confPwd").value;
      const btn  = document.getElementById("changBtn");

      clearMsg();
      if (!curr||!np||!cp) { showMsg("All fields are required.","error"); return; }
      if (np.length < 8)   { showMsg("New password must be at least 8 characters.","error"); return; }
      if (getStrength(np) < 3) { showMsg("Password is too weak. Add uppercase, numbers or symbols.","error"); return; }
      if (np !== cp)        { showMsg("Passwords do not match.","error"); return; }
      if (np === curr)      { showMsg("New password must be different from current password.","error"); return; }

      btn.disabled = true; btn.textContent = "Changing…";

      const user = auth.currentUser;
      // Re-authenticate first
      const cred = firebase.auth.EmailAuthProvider.credential(user.email, curr);
      user.reauthenticateWithCredential(cred).then(function() {
        return user.updatePassword(np);
      }).then(function() {
        showMsg("✅ Password changed successfully! Redirecting to dashboard…","success");
        setTimeout(function(){ window.location.replace("index.html"); }, 2000);
      }).catch(function(err) {
        btn.disabled = false; btn.textContent = "Change Password";
        const msgs = {
          "auth/wrong-password": "Current password is incorrect.",
          "auth/weak-password":  "New password is too weak.",
          "auth/requires-recent-login": "Session expired. Please log in again."
        };
        showMsg(msgs[err.code]||"Failed to change password. Please try again.","error");
      });
    }

    function showMsg(msg, type) {
      const el = document.getElementById("msg");
      el.className = "msg-box "+type; el.textContent = msg; el.style.display="block";
    }
    function clearMsg() { document.getElementById("msg").style.display="none"; }

    function toggleVis(id, btnId) {
      const f = document.getElementById(id), b = document.getElementById(btnId);
      f.type = f.type==="password" ? "text" : "password";
      b.textContent = f.type==="password" ? "Show" : "Hide";
    }
  </script>
  <style>
    *,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
    :root{--lime:#c8f135;--dark:#050d1a;--panel:#0a1220;--card:#101926;--border:rgba(255,255,255,0.07);--bdr2:rgba(255,255,255,0.13);--text:#eef4ff;--mu:#4e6070;--mu2:#849ab5;--red:#f05252;--grn:#22c55e;--fd:'Syne',sans-serif;--fb:'DM Sans',sans-serif;}
    body{min-height:100vh;background:var(--dark);color:var(--text);font-family:var(--fb);display:flex;align-items:center;justify-content:center;padding:24px;}
    .box{width:100%;max-width:460px;background:var(--panel);border:1px solid var(--border);border-radius:20px;padding:36px 32px;animation:rise 0.4s ease both;}
    @keyframes rise{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
    .logo-wrap{text-align:center;margin-bottom:28px;}
    .logo-wrap img{height:34px;filter:brightness(1.1);}
    h1{font-family:var(--fd);font-size:1.4rem;font-weight:800;color:var(--text);margin-bottom:4px;text-align:center;}
    .sub{font-size:0.82rem;color:var(--mu2);text-align:center;margin-bottom:6px;}
    .acc{font-size:0.76rem;color:var(--mu);text-align:center;margin-bottom:24px;font-family:'DM Mono',monospace;}
    .acc span{color:var(--lime);}
    .fg{margin-bottom:14px;}
    .fl{display:block;font-size:0.69rem;font-weight:600;color:var(--mu2);margin-bottom:6px;letter-spacing:0.8px;text-transform:uppercase;}
    .iw{position:relative;}
    .fi{width:100%;padding:12px 50px 12px 14px;background:var(--card);border:1.5px solid var(--border);border-radius:10px;color:var(--text);font-family:var(--fb);font-size:0.9rem;outline:none;transition:0.2s;}
    .fi:focus{border-color:rgba(200,241,53,0.45);background:rgba(200,241,53,0.03);box-shadow:0 0 0 3px rgba(200,241,53,0.07);}
    .fi::placeholder{color:#253040;}
    .st{position:absolute;right:13px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--mu2);cursor:pointer;font-size:11px;font-weight:600;font-family:var(--fb);padding:4px 6px;border-radius:4px;transition:0.15s;}
    .st:hover{color:var(--lime);}
    .strength-bar{display:flex;gap:4px;margin-top:7px;}
    .sb-seg{height:3px;border-radius:3px;flex:1;background:var(--border);transition:0.3s;}
    .str-lbl{font-size:0.72rem;margin-top:5px;font-weight:600;}
    .rules{background:var(--card);border:1px solid var(--border);border-radius:9px;padding:12px 14px;margin-bottom:16px;display:grid;gap:5px;}
    .rule{font-size:0.76rem;color:var(--mu);display:flex;align-items:center;gap:7px;}
    .rule.ok{color:var(--grn);}
    .rule::before{content:"○";flex-shrink:0;}
    .rule.ok::before{content:"✓";}
    .msg-box{display:none;padding:11px 14px;border-radius:9px;font-size:0.81rem;margin-bottom:14px;line-height:1.5;}
    .msg-box.error{background:rgba(240,82,82,0.1);border:1px solid rgba(240,82,82,0.25);color:#fca5a5;}
    .msg-box.success{background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.25);color:#86efac;}
    .btn{width:100%;padding:13px;background:var(--lime);color:#050d1a;border:none;border-radius:11px;font-family:var(--fd);font-size:0.95rem;font-weight:700;cursor:pointer;transition:0.2s;box-shadow:0 4px 20px rgba(200,241,53,0.22);margin-bottom:12px;}
    .btn:hover{background:#d4f545;transform:translateY(-1px);}
    .btn:disabled{opacity:0.6;cursor:not-allowed;transform:none;}
    .back{display:flex;align-items:center;justify-content:center;gap:5px;color:var(--mu2);font-size:0.8rem;text-decoration:none;transition:0.2s;}
    .back:hover{color:var(--lime);}
  </style>
</head>
<body>
<div class="box">
  <div class="logo-wrap">
    <img src="logo.jpeg" alt="SPark" onerror="this.outerHTML='<div style=\'font-family:Syne,sans-serif;font-size:1.3rem;font-weight:800;color:#eef4ff\'>S<span style=\'color:#c8f135\'>Park</span></div>'">
  </div>
  <h1>🔑 Change Password</h1>
  <p class="sub">Choose a new strong password for your account.</p>
  <p class="acc">Signed in as <span id="userEmail">—</span></p>

  <div class="fg">
    <label class="fl">Current Password</label>
    <div class="iw">
      <input class="fi" id="currPwd" type="password" placeholder="Your current password" autocomplete="current-password">
      <button class="st" onclick="toggleVis('currPwd','btn1')" id="btn1">Show</button>
    </div>
  </div>

  <div class="fg">
    <label class="fl">New Password</label>
    <div class="iw">
      <input class="fi" id="newPwd" type="password" placeholder="Min. 8 characters" autocomplete="new-password"
             oninput="updateStrength(this.value);checkRules(this.value)">
      <button class="st" onclick="toggleVis('newPwd','btn2')" id="btn2">Show</button>
    </div>
    <div class="strength-bar">
      <div class="sb-seg"></div><div class="sb-seg"></div>
      <div class="sb-seg"></div><div class="sb-seg"></div><div class="sb-seg"></div>
    </div>
    <div class="str-lbl" id="strengthLbl" style="color:var(--mu);">—</div>
  </div>

  <div class="rules" id="rulesBox">
    <div class="rule" id="r-len">At least 8 characters</div>
    <div class="rule" id="r-up">At least one uppercase letter (A-Z)</div>
    <div class="rule" id="r-num">At least one number (0-9)</div>
    <div class="rule" id="r-sym">At least one symbol (@, #, $, !)</div>
  </div>

  <div class="fg">
    <label class="fl">Confirm New Password</label>
    <div class="iw">
      <input class="fi" id="confPwd" type="password" placeholder="Repeat new password" autocomplete="new-password">
      <button class="st" onclick="toggleVis('confPwd','btn3')" id="btn3">Show</button>
    </div>
  </div>

  <div class="msg-box" id="msg"></div>
  <button class="btn" id="changBtn" onclick="doChangePassword()">Change Password</button>
  <a href="index.html" class="back">← Back to Dashboard</a>
</div>
<script>
  function checkRules(pwd) {
    const set = function(id, ok){ const el=document.getElementById(id); if(el){ el.className="rule"+(ok?" ok":""); } };
    set("r-len", pwd.length>=8);
    set("r-up",  /[A-Z]/.test(pwd));
    set("r-num", /[0-9]/.test(pwd));
    set("r-sym", /[^A-Za-z0-9]/.test(pwd));
  }
  document.addEventListener("keydown", function(e){ if(e.key==="Enter") doChangePassword(); });
</script>
</body>
</html>
